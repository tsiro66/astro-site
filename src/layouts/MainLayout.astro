---
import "../styles/global.css";

// Remove the @fontsource CSS imports — we'll declare @font-face manually in global.css
// import "@fontsource/syne/800.css";  ← DELETE
// import "@fontsource/syne/700.css";  ← DELETE
// import "@fontsource/syne/400.css";  ← DELETE

// Import hashed URLs so <link rel="preload"> always points to the right file
import syne800 from "@fontsource/syne/files/syne-latin-800-normal.woff2?url";
import syne700 from "@fontsource/syne/files/syne-latin-700-normal.woff2?url";
import syne400 from "@fontsource/syne/files/syne-latin-400-normal.woff2?url";
import syne800gr from "@fontsource/syne/files/syne-greek-800-normal.woff2?url";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "FLUX | Υπηρεσίες Υψηλής Απόδοσης",
  description = "Digital εμπειρίες χωρίς συμβιβασμούς στην ταχύτητα και τον σχεδιασμό.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="GR" />
    <meta name="geo.placename" content="Greece" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="el_GR" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!--
      Preload the fonts that appear above the fold.
      800 Latin + Greek = your H1 (LCP element).
      700 Latin = Navbar.
      These now load in parallel with the HTML, not after CSS is parsed.
    -->
    <link rel="preload" href={syne800}   as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={syne800gr} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={syne700}   as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={syne400}   as="font" type="font/woff2" crossorigin />

    <ClientRouter fallback="swap" />
  </head>
  <body class="bg-zinc-200 antialiased selection:bg-black selection:text-white">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-100 focus:p-4 focus:bg-white focus:text-black border-4 border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)]"
    >
      Μετάβαση στο περιεχόμενο
    </a>

    <div class="flex flex-col min-h-screen overflow-x-hidden w-full">
      <Navbar />
      <main id="main-content" class="grow" role="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>