---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "FLUX | Κατασκευή Ιστοσελίδων & E-shops - Premium Design & Ταχύτητα",
  description = "Εξειδικευμένη κατασκευή ιστοσελίδων και e-shops στην Ελλάδα. Εστιάζουμε στο Accessibility, το SEO και το High-End Design με Next.js και Astro.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Schema.org για LocalBusiness - Βοηθάει στο SEO στην Ελλάδα
const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "FLUX Web",
  // "image": "https://www.flux-web.com/og-image.jpg",
  "@id": "https://www.flux-web.com",
  "url": "https://www.flux-web.com",
  // "telephone": "+30XXXXXXXXXX",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "", 
    "addressLocality": "Athens",
    "postalCode": "",
    "addressCountry": "GR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 37.9838,
    "longitude": 23.7275
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  }
};
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="GR" />
    <meta name="geo.placename" content="Greece" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="el_GR" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.jpg', Astro.url)} /> <link rel="preload" href="/fonts/syne-v24-greek_latin-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/syne-v24-greek_latin-800.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/syne-v24-greek_latin-regular.woff2" as="font" type="font/woff2" crossorigin />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

    <ClientRouter fallback="swap" />
  </head>
  <body class="bg-zinc-200 antialiased selection:bg-black selection:text-white">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-100 focus:p-4 focus:bg-white focus:text-black border-4 border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)]"
    >
      Μετάβαση στο περιεχόμενο
    </a>

    <div class="flex flex-col min-h-screen overflow-x-hidden w-full">
      <Navbar />
      <main id="main-content" class="grow" role="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>