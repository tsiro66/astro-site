---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";

const values = [
  {
    num: "01",
    title: "Ταχύτητα",
    desc: "Κάθε millisecond μετράει. Χτίζουμε με performance-first νοοτροπία. Χρησιμοποιούμε Astro, Next.js και static generation για sites που φορτώνουν σχεδόν ακαριαία.",
    // Purple Card
    classes: "bg-violet-600 text-white",
    numberBox: "bg-white text-black group-hover:bg-volt",
  },
  {
    num: "02",
    title: "Ειλικρίνεια",
    desc: "Δεν πουλάμε αέρα. Σου λέμε ακριβώς τι χρειάζεσαι, τι κοστίζει και πότε θα είναι έτοιμο. Χωρίς surprises, χωρίς κρυφές χρεώσεις.",
    // Volt Card
    classes: "bg-volt text-black",
    numberBox: "bg-white text-black group-hover:bg-black group-hover:text-white",
  },
  {
    num: "03",
    title: "Αποτέλεσμα",
    desc: "Δεν μας ενδιαφέρει μόνο το πώς φαίνεται — μας ενδιαφέρει το πώς αποδίδει. Κάθε decision παίρνεται με γνώμονα τον στόχο σου.",
    // White Card
    classes: "bg-white text-black",
    numberBox: "bg-white text-black group-hover:bg-volt",
  },
];
---

<MainLayout title="Ποιοι Είμαστε | Flux">
  <section class="pt-32 md:pt-48 px-6 font-syne">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">
          Ποιοι Είμαστε
        </h2>
        <span class="relative inline-block text-4xl md:text-5xl tracking-tighter">
          <span class="relative text-4xl z-10 bg-violet-400 px-2">Φτιάχνουμε το web σωστά.</span>
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 rotate-2">
        <div class="border-4 border-black bg-volt p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
          <p class="text-xl md:text-2xl font-bold leading-snug tracking-tight">
            Η Flux δεν είναι απλώς ένα web agency. Είμαστε μανιακοί με την
            ταχύτητα, το design και την αποδοτικότητα — και το δείχνουμε με
            κάθε project που παραδίδουμε.
          </p>
        </div>
        <div class="border-4 border-black bg-white p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
          <p class="text-xl md:text-2xl font-bold leading-snug text-zinc-700">
            Ξεκινήσαμε από την απλή παρατήρηση ότι οι περισσότερες ιστοσελίδες
            στην ελληνική αγορά είναι αργές, άσχημες και ακριβές. Αποφασίσαμε
            να αλλάξουμε αυτό — προσφέροντας premium αποτελέσματα σε τιμές που
            δεν σε αναγκάζουν να επιλέξεις ανάμεσα σε quality και budget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-24 font-syne -rotate-2">
    <div class="max-w-6xl mx-auto">
      <h3 class="text-3xl md:text-4xl font-bold tracking-tighter mb-12">
        <span class="bg-violet-400 px-2">Τι μας οδηγεί</span>
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          values.map((v) => (
            <div
              class:list={[
                "group border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-4px] hover:translate-y-[-4px] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200",
                v.classes,
              ]}
            >
              <div
                class:list={[
                  "w-12 h-12 border-4 border-black mb-6 flex items-center justify-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] font-black text-lg transition-colors",
                  v.numberBox,
                ]}
              >
                {v.num}
              </div>
              <h4 class="text-2xl md:text-3xl font-bold mb-4 tracking-tight">
                {v.title}
              </h4>
              <p class="text-lg leading-snug">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 pb-32 font-syne rotate-2">
    <div class="max-w-6xl mx-auto">
      <div class="border-4 border-volt bg-black p-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col md:flex-row items-center justify-between gap-8 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
        <div>
          <h3 class="text-3xl md:text-5xl font-bold tracking-tighter text-white mb-2">
            Έτοιμος να ξεκινήσουμε;
          </h3>
          <p class="text-zinc-400 text-lg">
            Μία κλήση αρκεί για να καταλάβεις αν ταιριάζουμε.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 shrink-0">
          <Button variant="primaryDark" href="/contact">Φόρμα Επικοινωνίας</Button>
          <Button variant="outlineDark" href="/services">Δες Υπηρεσίες</Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
</style>