---
import "../styles/global.css";
import Button from "../components/Button.astro";
import Footer from "../components/Footer.astro";
const lastUpdated = "24 Φεβρουαρίου 2026";

const sections = [
  {
    id: "collection",
    number: "01",
    title: "Ποια Δεδομένα Συλλέγουμε",
    content: [
      "Συλλέγουμε μόνο τα δεδομένα που είναι απαραίτητα για να σας παρέχουμε τις υπηρεσίες μας. Αυτά περιλαμβάνουν:",
      "**Στοιχεία επικοινωνίας**: Όνομα, email, αριθμός τηλεφώνου — μόνο όταν τα παρέχετε εσείς μέσω της φόρμας επικοινωνίας.",
      "**Τεχνικά δεδομένα**: Διεύθυνση IP, τύπος browser, λειτουργικό σύστημα, σελίδες που επισκεφτήκατε και χρόνος παραμονής — για ανάλυση απόδοσης του site.",
    ],
  },
  {
    id: "usage",
    number: "02",
    title: "Πώς Χρησιμοποιούμε τα Δεδομένα",
    content: [
      "Τα δεδομένα σας χρησιμοποιούνται αποκλειστικά για:",
      "**Επικοινωνία**: Απάντηση στα αιτήματά σας και αποστολή προσφορών που ζητήσατε.",
      "**Βελτίωση υπηρεσιών**: Ανάλυση της χρήσης του site για βελτίωση της εμπειρίας χρήστη.",
      "**Νομική υποχρέωση**: Συμμόρφωση με νομικές απαιτήσεις όπου απαιτείται.",
      "Δεν πουλάμε, δεν ενοικιάζουμε και δεν μοιραζόμαστε τα δεδομένα σας με τρίτους για εμπορικούς σκοπούς. Ποτέ.",
    ],
  },
  {
    id: "storage",
    number: "03",
    title: "Αποθήκευση & Ασφάλεια",
    content: [
      "Τα δεδομένα σας αποθηκεύονται σε ασφαλείς servers εντός της Ευρωπαϊκής Ένωσης, σε πλήρη συμμόρφωση με τον GDPR.",
      "**Κρυπτογράφηση**: Όλες οι μεταδόσεις δεδομένων γίνονται μέσω HTTPS/TLS.",
      "**Περίοδος διατήρησης**: Τα δεδομένα επικοινωνίας διατηρούνται για 3 χρόνια από την τελευταία επαφή.",
      "**Πρόσβαση**: Μόνο εξουσιοδοτημένα μέλη της ομάδας μας έχουν πρόσβαση στα δεδομένα σας.",
    ],
  },
  {
    id: "rights",
    number: "04",
    title: "Τα Δικαιώματά Σας (GDPR)",
    content: [
      "Ως υποκείμενο δεδομένων στην ΕΕ, έχετε τα ακόλουθα δικαιώματα:",
      "**Δικαίωμα πρόσβασης**: Μπορείτε να ζητήσετε αντίγραφο των δεδομένων που διατηρούμε για εσάς.",
      "**Δικαίωμα διόρθωσης**: Μπορείτε να ζητήσετε τη διόρθωση ανακριβών δεδομένων.",
      '**Δικαίωμα διαγραφής**: Μπορείτε να ζητήσετε τη διαγραφή των δεδομένων σας ("δικαίωμα στη λήθη").',
      "**Δικαίωμα φορητότητας**: Μπορείτε να ζητήσετε τα δεδομένα σας σε δομημένη, μηχαναγνώσιμη μορφή.",
      "**Δικαίωμα εναντίωσης**: Μπορείτε να αντιταχθείτε στην επεξεργασία των δεδομένων σας ανά πάσα στιγμή.",
    ],
  },
  {
    id: "contact",
    number: "05",
    title: "Επικοινωνία & Υπεύθυνος Δεδομένων",
    content: [
      "Για οποιοδήποτε ερώτημα σχετικά με την επεξεργασία των δεδομένων σας ή για την άσκηση των δικαιωμάτων σας, επικοινωνήστε μαζί μας:",
      "**Email**: info@flux-web.com",
      "**Προθεσμία απάντησης**: Απαντάμε σε όλα τα αιτήματα εντός 30 ημερών, σύμφωνα με τον GDPR.",
      "Έχετε επίσης το δικαίωμα να υποβάλετε καταγγελία στην Αρχή Προστασίας Δεδομένων Προσωπικού Χαρακτήρα (ΑΠΔΠΧ) στο www.dpa.gr.",
    ],
  },
];
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Πολιτική Απορρήτου - Flux Web Agency. Μάθετε πώς προστατεύουμε τα δεδομένα σας σύμφωνα με τον GDPR." />
    <title>Πολιτική Απορρήτου | FLUX</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="text-black antialiased bg-zinc-200 selection:bg-volt">
    <header
      class="sticky top-0 z-50 border-b-4 border-black flex items-center justify-between px-6 py-4 font-syne bg-white"
    >
      <Button variant="primary" href="/"> ← Πίσω </Button>
      <a
        href="/"
        class="text-3xl md:text-5xl font-black tracking-tight no-underline text-black"
      >
        FLUX
      </a>
    </header>

    <div
      class="relative overflow-hidden border-b-4 border-black px-6 py-16 font-syne"
    >
      <div class="relative max-w-4xl mx-auto">
        <div
          class="inline-block bg-volt border-4 border-black px-3 py-1 text-xs font-bold tracking-widest uppercase mb-5"
        >
          Νομικό Έγγραφο
        </div>
        <h1
          class="text-5xl md:text-7xl font-bold tracking-tighter leading-none mb-6"
        >
          Πολιτική<br /><em class="text-violet-600 font-normal">Απορρήτου</em>
        </h1>
        <div class="flex flex-wrap gap-3 items-center text-sm font-bold">
          <span
            class="bg-black text-white border-4 border-black px-3 py-1.5 font-bold"
            >GDPR Compliant</span
          >
          <time datetime="2026-02-24" class="border-4 border-black px-3 py-1.5 font-bold"
            >Τελευταία ενημέρωση: {lastUpdated}</time
          >
        </div>
      </div>
    </div>

    <div class="lg:hidden border-b-4 border-black px-6 font-syne sticky top-[77px] bg-zinc-200 z-40">
      <button
        id="tocToggle"
        aria-expanded="false"
        aria-controls="mobileTocList"
        class="w-full flex items-center justify-between py-4 bg-transparent border-none cursor-pointer font-syne font-bold text-sm tracking-widest uppercase text-black"
      >
        <span>Περιεχόμενα</span>
        <span id="tocArrow" class="text-xl transition-transform duration-200" aria-hidden="true"
          >▾</span
        >
      </button>
      <nav id="mobileTocList" class="hidden flex-col gap-1 pb-4">
        {
          sections.map((s) => (
            <a
              href={`#${s.id}`}
              class="flex items-center gap-3 px-3 py-2.5 text-sm font-bold text-black no-underline border-2 border-transparent transition-all hover:bg-volt hover:border-black"
            >
              <span class="text-xs opacity-40 font-bold">
                {s.number}
              </span>
              {s.title}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="max-w-7xl mx-auto grid lg:grid-cols-[260px_1fr] font-syne relative">
      <aside
        class="hidden lg:block border-r-4 border-black px-6 py-8 sticky top-[100px] self-start max-h-[calc(100vh-100px)] overflow-y-auto"
      >
        <p
          class="text-xs font-bold tracking-widest uppercase opacity-40 mb-5"
        >
          Περιεχόμενα
        </p>
        <nav aria-label="Πλοήγηση εγγράφου">
          <ul class="list-none flex flex-col gap-1 p-0 m-0">
            {
              sections.map((s) => (
                <li>
                  <a
                    href={`#${s.id}`}
                    data-toc={s.id}
                    class="toc-link flex items-center gap-2.5 px-3 py-2 text-sm font-bold text-black no-underline border-2 border-transparent transition-all hover:bg-volt hover:border-black"
                  >
                    <span class="text-[0.7rem] opacity-40 font-bold shrink-0">
                      {s.number}
                    </span>
                    {s.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </aside>

      <main class="px-6 py-10 md:px-10 md:py-12 bg-white">
        <div
          class="flex items-start gap-4 border-4 border-black bg-volt px-6 py-5 mb-10"
        >
          <p class="text-sm font-bold leading-relaxed text-black">
            Σεβόμαστε την ιδιωτικότητά σας. Αυτή η πολιτική εξηγεί με απλά λόγια
            τι δεδομένα συλλέγουμε, γιατί τα χρειαζόμαστε και πώς τα
            προστατεύουμε — χωρίς νομική γλώσσα και κρυφά γράμματα.
          </p>
        </div>

        {
          sections.map((section) => (
            <section
              id={section.id}
              class="policy-section pb-10 mb-10 border-b-4 border-black last:border-b-0 last:mb-0 scroll-mt-32"
            >
              <div class="flex items-start gap-3 mb-6">
                <span class="bg-violet-600 text-white text-xs font-bold px-2 py-1 shrink-0 mt-1" aria-hidden="true">
                  {section.number}
                </span>
                <h2 class="text-2xl md:text-3xl font-bold tracking-tight leading-tight">
                  {section.title}
                </h2>
              </div>
              <div class="flex flex-col gap-3 sm:pl-11">
                {section.content.map((para, i) => (
                  <p
                    class:list={[
                      "text-base leading-relaxed",
                      i === 0
                        ? "font-bold text-black"
                        : "font-semibold text-zinc-600",
                    ]}
                    set:html={para.replace(
                      /\*\*(.*?)\*\*/g,
                      '<strong class="text-black font-bold">$1</strong>',
                    )}
                  />
                ))}
              </div>
            </section>
          ))
        }
      </main>
    </div>

    <Footer />

    <script>
      function initPrivacy() {
        const toggle = document.getElementById("tocToggle");
        const list = document.getElementById("mobileTocList");
        const arrow = document.getElementById("tocArrow");

        toggle?.addEventListener("click", () => {
          const isHidden = list?.classList.contains("hidden");
          list?.classList.toggle("hidden", !isHidden);
          list?.classList.toggle("flex", isHidden);
          toggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
          if (arrow) arrow.style.transform = isHidden ? "rotate(180deg)" : "";
        });

        const tocLinks = document.querySelectorAll<HTMLElement>(".toc-link, #mobileTocList a");
        const policySections = document.querySelectorAll(".policy-section");

        const observerOptions = {
          rootMargin: "-20% 0px -70% 0px",
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              tocLinks.forEach((link) => {
                const isActive = link.getAttribute('href') === `#${id}` || (link as HTMLElement).dataset.toc === id;
                if (link.classList.contains('toc-link')) {
                   link.classList.toggle("bg-black", isActive);
                   link.classList.toggle("text-white", isActive);
                   link.classList.toggle("border-black", isActive);
                   link.classList.toggle("border-transparent", !isActive);
                }
              });
            }
          });
        }, observerOptions);

        policySections.forEach((s) => observer.observe(s));
      }

      initPrivacy();
      document.addEventListener("astro:after-swap", initPrivacy);
    </script>
  </body>
</html>