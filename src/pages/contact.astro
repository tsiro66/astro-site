---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Contact | FLUX" lang="el">
  <section class="pt-32 md:pt-48 pb-24 px-6 font-syne">
    <div class="max-w-6xl mx-auto">
      
     <div class="mb-16">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">
          Επικοινωνία
        </h2>
        <span class="relative inline-block text-4xl">
          <span class="relative z-10 bg-volt">Πες μας για το project σου. </span>
        </span>
      </div>

      <div class="grid lg:grid-cols-12 gap-12">
        
        <div class="lg:col-span-7 bg-white border-4 border-black p-8 md:p-12 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-2 hover:rotate-0 hover:-translate-y-2 hover:-translate-x-2 hover:shadow-[20px_20px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
          <form class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-sm font-bold uppercase">Ονοματεπώνυμο</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Όνομα" 
                class="w-full border-4 border-black p-4 text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="text-sm font-bold uppercase">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="your@email.com" 
                class="w-full border-4 border-black p-4 text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-sm font-bold uppercase">Το Project σου</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                placeholder="Πες μας για το project σου..." 
                class="w-full border-4 border-black p-4 text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30 resize-none"
              ></textarea>
            </div>

            <Button variant="primary">
              Αποστολή Μυνήματος
            </Button>
          </form>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-8">
          <div class="bg-violet-600 border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-white -rotate-2 hover:rotate-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
            <h3 class="text-2xl font-black uppercase mb-4">Άμεση Επικοινωνία</h3>
            <p class="font-bold mb-2">Email: <span class="bg-pink px-2">info@flux-web.com</span></p>
            <p class="font-bold">Τηλέφωνο: <span class="bg-pink px-2">+30 210 XX XX XXX</span></p>
          </div>

          <div class="bg-volt border-4 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-black rotate-2 hover:rotate-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
            <h3 class="text-2xl font-black uppercase mb-4">Γιατί στη Flux;</h3>
            <ul class="font-bold space-y-2">
              <li><span class="bg-blue px-2">✓ Απάντηση σε {'<'} 24 ώρες</span></li>
              <li><span class="bg-blue px-2">✓ Custom-made προσφορά</span></li>
              <li><span class="bg-blue px-2">✓ Τα πιο γρήγορα site στην Ελλάδα</span></li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</MainLayout>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
</style>