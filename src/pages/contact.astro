---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Contact | FLUX" lang="el">
  <section class="pt-24 md:pt-48 pb-24 px-4 md:px-6 font-syne">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 md:mb-16">
        <h2 class="text-3xl md:text-6xl font-bold tracking-tighter mb-4">
          Επικοινωνία
        </h2>
          <span class="relative z-10 bg-volt text-2xl md:text-4xl"
            >Πες μας για το project σου.
          </span>
      </div>

      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
        <div
          class="lg:col-span-7 bg-white border-4 border-black p-6 md:p-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] md:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-1 md:rotate-2 hover:rotate-0 hover:-translate-y-2 hover:-translate-x-2 hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all duration-200"
        >
          <div
            id="success-message"
            class="hidden flex-col gap-4 text-center py-8 md:py-12"
          >
            <h3 class="text-2xl md:text-3xl font-black uppercase">Ευχαριστούμε!</h3>
            <p class="font-bold text-lg md:text-xl">
              Το μήνυμα στάλθηκε. Θα επικοινωνήσουμε σύντομα.
            </p>
            <Button href="/contact">Αποστολή νέου μηνύματος</Button>
          </div>

          <form id="contact-form" class="flex flex-col gap-5 md:gap-8" novalidate>
            <div class="flex flex-col gap-2">
              <label for="name" class="text-xs font-bold uppercase"
                >Ονοματεπώνυμο</label
              >
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Όνομα"
                required
                class="contact-input w-full border-4 border-black p-3 md:p-4 text-lg md:text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30"
              />
            </div>

            <div class="grid md:grid-cols-2 gap-5 md:gap-8">
              <div class="flex flex-col gap-2">
                <label for="email" class="text-xs font-bold uppercase"
                  >Email</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="your@email.com"
                  required
                  class="contact-input w-full border-4 border-black p-3 md:p-4 text-lg md:text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label for="phone" class="text-xs font-bold uppercase"
                  >Τηλέφωνο</label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="69XXXXXXXX"
                  required
                  pattern="[0-9]{10,}"
                  class="contact-input w-full border-4 border-black p-3 md:p-4 text-lg md:text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30"
                />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-xs font-bold uppercase"
                >Το Project σου</label
              >
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Πες μας για το project σου..."
                required
                class="contact-input w-full border-4 border-black p-3 md:p-4 text-lg md:text-xl font-bold focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all placeholder:opacity-30 resize-none"
              ></textarea>
            </div>

            <Button variant="primary" type="submit" id="submit-button" class="w-full md:w-auto">
              Αποστολή Μηνύματος
            </Button>
            <p id="error-message" class="hidden text-red-600 text-sm font-bold">
              Παρακαλώ συμπληρώστε σωστά όλα τα πεδία.
            </p>
          </form>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6 md:gap-8">
          <div
            class="bg-violet-600 border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-white -rotate-1 md:-rotate-2 hover:rotate-0 hover:-translate-y-1 hover:-translate-x-1 transition-all duration-200"
          >
            <h3 class="text-xl md:text-2xl font-black uppercase mb-4">
              Άμεση Επικοινωνία
            </h3>
            <p class="font-bold mb-2 text-sm md:text-base">
              Email: <span class="bg-pink px-2 text-black"
                >info@flux-web.com</span>
            </p>
            <p class="font-bold text-sm md:text-base">
              Τηλέφωνο: <span class="bg-pink px-2 text-black"
                >+30 210 XX XX XXX</span>
            </p>
          </div>

          <div
            class="bg-volt border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] text-black rotate-1 md:rotate-2 hover:rotate-0 hover:-translate-y-1 hover:-translate-x-1 transition-all duration-200"
          >
            <h3 class="text-xl md:text-2xl font-black uppercase mb-4">Γιατί στη Flux;</h3>
            <ul class="font-bold space-y-2 text-sm md:text-base">
              <li>
                <span class="bg-blue px-2">✓ Απάντηση σε &lt; 24 ώρες</span>
              </li>
              <li><span class="bg-blue px-2">✓ Custom-made προσφορά</span></li>
              <li>
                <span class="bg-blue px-2"
                  >✓ Τα πιο γρήγορα site στην Ελλάδα</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const successMsg = document.getElementById("success-message");
    const errorMsg = document.getElementById("error-message");
    const submitBtn = document.getElementById("submit-button");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      form.classList.add("was-validated");

      if (!form.checkValidity()) {
        errorMsg?.classList.remove("hidden");
        return;
      }

      errorMsg?.classList.add("hidden");
      if (submitBtn) submitBtn.innerText = "Στέλνουμε...";

      const formData = new FormData(form);

      try {
        const response = await fetch("/api/send-email", {
          method: "POST",
          body: formData,
        });

        if (response.ok) {
          form?.classList.add("hidden");
          successMsg?.classList.remove("hidden");
          successMsg?.classList.add("flex");
        } else {
          errorMsg?.classList.remove("hidden");
          if (submitBtn) submitBtn.innerText = "Αποστολή Μηνύματος";
        }
      } catch (error) {
        errorMsg?.classList.remove("hidden");
        if (submitBtn) submitBtn.innerText = "Αποστολή Μηνύματος";
      }
    });
  });
</script>

<style>
  .was-validated .contact-input:invalid {
    border-color: #dc2626;
    box-shadow: 4px 4px 0px 0px rgba(220, 38, 38, 1);
  }
</style>