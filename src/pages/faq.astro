---
import MainLayout from "../layouts/MainLayout.astro";

const faqs = [
  {
    q: "Πόσο χρόνο διαρκεί η κατασκευή μιας ιστοσελίδας;",
    a: "Aνάλογα με την πολυπλοκότητα του project και τις ανάγκες σας, μπορεί να διαρκέσει από 2 εβδομάδες για μία απλή ιστοσελίδα μέχρι και 6 μήνες για ένα πολύπλοκο e-shop.",
  },
  {
    q: "Προσφέρετε υποστήριξη μετά την παράδοση;",
    a: "Φυσικά. Παραμένουμε δίπλα σας για οποιαδήποτε τεχνική υποστήριξη ή αναβάθμιση χρειαστεί το ψηφιακό σας προϊόν.",
  },
  {
    q: "Θα είναι η ιστοσελίδα μου λειτουργική σε κινητές συσκευές;",
    a: "Κάθε project μας σχεδιάζεται με 'Mobile First' προσέγγιση, εξασφαλίζοντας τέλεια εμπειρία σε κάθε συσκευή.",
  },
  {
    q: "Θα μπορώ να ανανεώνω το περιεχόμενο μόνος μου;",
    a: "Φυσικά. Κατασκευάζουμε το site σας με φιλικό περιβάλλον διαχείρισης, ώστε να μπορείτε να αλλάζετε κείμενα, φωτογραφίες και προϊόντα εύκολα, χωρίς να χρειάζεστε γνώσεις προγραμματισμού.",
  },
  {
    q: "Περιλαμβάνεται το SEO στην κατασκευή;",
    a: "Κάθε project παραδίδεται με 'Technical SEO' βελτιστοποίηση. Αυτό σημαίνει καθαρό κώδικα, μεγάλες ταχύτητες φόρτωσης και σωστή δομή, ώστε οι μηχανές αναζήτησης να σας βρίσκουν εύκολα.",
  },
  {
    q: "Πόσο κοστίζει η κατασκευή ενός eshop στην Ελλάδα το 2026;",
    a: "Το κόστος εξαρτάται από τις απαιτήσεις (αριθμός προϊόντων, διασυνδέσεις, design). Στη Flux Web προτείνουμε λύσεις που ξεκινούν από ένα βασικό λειτουργικό μοντέλο και επεκτείνονται καθώς μεγαλώνετε. Λόγω της έναρξης λειτουργίας μας, προσφέρουμε ειδικές τιμές γνωριμίας για τους πρώτους μας συνεργάτες, διατηρώντας την υψηλή ποιότητα κατασκευής σε πιο προσιτό κόστος.",
  },
  {
    q: "Ποιο είναι το κόστος για ένα απλό site ή μια Landing Page;",
    a: "Μια Landing Page ή ένα site παρουσίασης είναι η ιδανική λύση για ελεύθερους επαγγελματίες που θέλουν άμεση και επαγγελματική online παρουσία. Οι τιμές διαμορφώνονται ανάλογα με τις σελίδες και το περιεχόμενο, ενώ αυτή την περίοδο τρέχουν ειδικές προσφορές γνωριμίας για νέα projects που θέλουν να ξεχωρίσουν στην ελληνική αγορά.",
  },
  {
    q: "Τι είναι η Προσβασιμότητα (Accessibility) και γιατί την χρειάζεται η επιχείρησή μου;",
    a: "Η προσβασιμότητα διασφαλίζει ότι το site σας είναι φιλικό προς όλους, συμπεριλαμβανομένων ατόμων με αναπηρίες. Εκτός από το ηθικό κομμάτι, η Google επιβραβεύει τα προσβάσιμα sites με υψηλότερη κατάταξη, ενώ η νομοθεσία (European Accessibility Act) το καθιστά πλέον υποχρεωτικό για πολλές επιχειρήσεις εντός του 2026.",
  },
  {
    q: "Τι τεχνολογίες χρησιμοποιείτε;",
    a: "Δεν περιοριζόμαστε σε μία λύση. Επιλέγουμε το tech stack ανάλογα με τις ανάγκες σας—από Astro για κορυφαία ταχύτητα σε στατικά sites, μέχρι Next.js για σύνθετα web apps. Στόχος μας είναι πάντα το maximum performance και η μελλοντική επεκτασιμότητα.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};
---

<MainLayout title="Συχνές Ερωτήσεις | Flux">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <section
    class="pt-32 md:pt-48 px-6 font-syne overflow-hidden"
    aria-labelledby="faq-heading"
  >
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <h1
          id="faq-heading"
          class="text-4xl md:text-6xl font-bold tracking-tighter mb-4"
        >
          Συχνές ερωτήσεις
        </h1>

        <span class="relative inline-block text-4xl">
          <span class="relative z-10 bg-violet-400 px-2 text-black"
            >Λύνουμε τις απορίες σου πριν καν τις σκεφτείς.</span
          >
        </span>
      </div>

      <div class="space-y-12 py-10">
        {
          faqs.map((faq, index) => (
            <details
              class:list={[
                "group border-4 border-black bg-white shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] open:shadow-[10px_10px_0px_0px_rgba(124,58,237,1)] transition-all duration-300 transform-gpu",
                index % 2 === 0
                  ? "rotate-1 md:rotate-[1.5deg]"
                  : "-rotate-1 md:-rotate-[1.5deg]",
              ]}
            >
              <summary class="list-none cursor-pointer p-6 md:p-8 flex items-center justify-between outline-none focus-visible:bg-zinc-50">
                <h2 class="text-lg md:text-2xl font-bold tracking-tight leading-tight pr-4">
                  {faq.q}
                </h2>
                <div class="relative w-8 h-8 shrink-0" aria-hidden="true">
                  <span class="absolute top-1/2 left-0 w-full h-1 bg-black -translate-y-1/2 transition-transform duration-300 group-open:rotate-180" />
                  <span class="absolute top-1/2 left-0 w-full h-1 bg-black -translate-y-1/2 rotate-90 transition-transform duration-300 group-open:rotate-0" />
                </div>
              </summary>

              <div class="px-6 pb-8 md:px-8 md:pb-10 animate-fade-in">
                <div class="p-6 bg-volt border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                  <p class="text-lg font-bold leading-relaxed text-black">
                    {faq.a}
                  </p>
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>

<style>
  summary::-webkit-details-marker {
    display: none;
  }

  .transform-gpu {
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.3s ease-out forwards;
  }
</style>
