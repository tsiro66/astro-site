---
// src/components/Navbar.astro
import Button from "./Button.astro";

const navLinks = [
  { href: "/services", label: "ΥΠΗΡΕΣΙΕΣ" },
  { href: "/faq", label: "ΕΡΩΤΗΣΕΙΣ" },
  { href: "/contact", label: "ΕΠΙΚΟΙΝΩΝΙΑ" },
  { href: "/about", label: "ΠΟΙΟΙ ΕΙΜΑΣΤΕ" },
];

const { pathname } = Astro.url;
const normalizedPathname = pathname.replace(/\/$/, "") || "/";
---

<header
  class="fixed top-0 w-full z-50 px-4 lg:px-6 py-4 lg:py-8 pointer-events-none"
>
  <nav
    class="max-w-6xl mx-auto h-16 lg:h-20 px-6 lg:px-8 rounded-full border-2 border-black bg-white flex items-center justify-between shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] relative pointer-events-auto transform-gpu"
    aria-label="Κύριο Μενού"
  >
    <div class="flex items-center gap-2">
      <a
        href="/"
        class="font-syne font-extrabold text-2xl tracking-tighter uppercase focus-visible:outline-violet-600"
        aria-label="FLUX Αρχική">FLUX</a
      >
    </div>

    <ul class="hidden lg:flex items-center gap-8">
      {
        navLinks.map((link) => {
          const isActive = normalizedPathname === link.href;
          return (
            <li>
              <a
                href={link.href}
                aria-current={isActive ? "page" : undefined}
                class="font-syne font-bold text-sm hover:text-violet-600 transition-colors uppercase tracking-tight focus-visible:outline-violet-600 group"
              >
                <span class="relative inline-block">
                  <span class="relative z-10">{link.label}</span>
                  {isActive && (
                    <span
                      class="absolute bottom-0 left-0 w-full h-3 bg-volt -rotate-1 -z-0"
                      aria-hidden="true"
                    />
                  )}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-3">
      <Button
        variant="primary"
        href="tel:+302100000000"
        class="hidden lg:flex text-xs lg:text-sm py-2 px-4"
      >
        Τηλεφώνησέ μας
      </Button>

      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2 border-2 border-black rounded-lg bg-volt shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-[1px_1px_0px_0px_rgba(0,0,0,1)] active:translate-x-[1px] active:translate-y-[1px] transition-all"
        aria-label="Άνοιγμα μενού"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span
          class="w-6 h-0.5 bg-black transition-transform duration-200"
          id="bar-1"></span>
        <span
          class="w-6 h-0.5 bg-black transition-opacity duration-200"
          id="bar-2"></span>
        <span
          class="w-6 h-0.5 bg-black transition-transform duration-200"
          id="bar-3"></span>
      </button>
    </div>

    <nav
      id="mobile-menu"
      class="fixed inset-x-1 top-24 bg-white border-4 border-black p-8 rounded-3xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col gap-6 text-center lg:hidden opacity-0 scale-95 pointer-events-none transition-all duration-200 ease-out z-50"
    >
        <ul class="flex flex-col gap-6">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="mobile-link font-syne font-black text-xl sm:text-3xl uppercase tracking-tighter hover:text-violet-600 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <hr class="border-t-2 border-black opacity-10" />
        <Button
          variant="primary"
          href="/contact"
          class="w-full justify-center text-lg"
        >
          Ξεκινάμε
        </Button>
      </nav>
  </nav>

  <div class="max-w-6xl mx-auto px-10 pointer-events-none mt-1">
    <div
      id="scroll-line"
      role="progressbar"
      aria-label="Πρόοδος ανάγνωσης σελίδας"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      class="h-1 md:h-1.5 bg-pink w-0 rounded-full transition-all duration-75 ease-out shadow-[1px_1px_0px_0px_rgba(0,0,0,1)]"
    >
    </div>
  </div>
</header>

<script>
  function setupNavbar() {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const line = document.getElementById("scroll-line");
    const b1 = document.getElementById("bar-1");
    const b2 = document.getElementById("bar-2");
    const b3 = document.getElementById("bar-3");

    let isScrolling = false;

    const toggleMenu = () => {
      const isExpanded = menuToggle?.getAttribute("aria-expanded") === "true";
      const nextState = !isExpanded;

      menuToggle?.setAttribute("aria-expanded", nextState.toString());

      if (nextState) {
        // OPENING: Remove blocking classes instantly
        mobileMenu?.classList.remove(
          "opacity-0",
          "scale-95",
          "pointer-events-none",
        );
        mobileMenu?.classList.add("opacity-100", "scale-100");
        if (b1 && b2 && b3) {
          b1.style.transform = "translateY(8px) rotate(45deg)";
          b2.style.opacity = "0";
          b3.style.transform = "translateY(-8px) rotate(-45deg)";
        }
      } else {
        // CLOSING: Re-add blocking classes instantly
        mobileMenu?.classList.add(
          "opacity-0",
          "scale-95",
          "pointer-events-none",
        );
        mobileMenu?.classList.remove("opacity-100", "scale-100");
        if (b1 && b2 && b3) {
          b1.style.transform = "none";
          b2.style.opacity = "1";
          b3.style.transform = "none";
        }
      }
    };

    menuToggle?.addEventListener("click", toggleMenu);

    // Close on link click
    document.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", () => {
        if (menuToggle?.getAttribute("aria-expanded") === "true") toggleMenu();
      });
    });

    // Scroll Progress logic
    const updateLine = () => {
      if (line) {
        const winScroll = window.scrollY;
        const height =
          document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        line.style.width = `${scrolled}%`;
      }
      isScrolling = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!isScrolling) {
          window.requestAnimationFrame(updateLine);
          isScrolling = true;
        }
      },
      { passive: true },
    );
  }

  setupNavbar();
  document.addEventListener("astro:after-swap", setupNavbar);
</script>
