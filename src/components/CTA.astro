---
import Button from "./Button.astro";


---
<section class="px-6 font-syne">
  <div class="max-w-6xl mx-auto">
    <div
      class="border-4 border-volt bg-black p-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col md:flex-row items-center justify-between gap-8 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-200"
    >
      <div>
        <h3
          class="text-3xl md:text-5xl font-bold tracking-tighter text-white mb-2"
        >
          Έτοιμος να ξεκινήσουμε;
        </h3>
        <p class="text-zinc-400 text-lg">
          Μία κλήση αρκεί για να καταλάβεις αν ταιριάζουμε.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0">
        <Button variant="primaryDark" href="/contact">Φόρμα Επικοινωνίας</Button
        >
        <Button variant="outlineDark" href="/services">Δες Υπηρεσίες</Button>
      </div>
    </div>
  </div>
</section>
