---
import Button from "./Button.astro";
---
<section class="py-20 px-6 font-syne" aria-labelledby="cta-heading">
  <div class="max-w-6xl mx-auto">
    <div
      class="border-4 border-volt bg-black p-8 md:p-16 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col md:flex-row items-center justify-between gap-8 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all duration-300 will-change-transform"
    >
      <header class="text-center md:text-left">
        <h2
          id="cta-heading"
          class="text-3xl md:text-5xl font-black tracking-tighter text-white mb-4"
        >
          Έτοιμος να ξεκινήσουμε;
        </h2>
        <p class="text-zinc-300 text-lg md:text-xl font-medium max-w-xl">
          Εποικοινώνησε μαζί μας για να δούμε πώς μπορούμε να σε βοηθήσουμε.
        </p>
      </header>

      <div class="flex flex-col gap-4 shrink-0 w-full md:w-auto">
        <Button variant="primaryDark" href="/contact" class="w-full sm:w-auto">
          Φόρμα Επικοινωνίας
        </Button>
        <Button variant="outlineDark" href="/services" class="w-full sm:w-auto">
          Δες Υπηρεσίες
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .will-change-transform {
    will-change: transform, box-shadow;
  }
</style>