---
const marqueeItems = [
  { text: "LAUNCH OFFER", isItalic: true, color: "text-white" },
  { text: "★", isItalic: false, color: "text-violet-500" },
  { text: "ΠΡΟΝΟΜΙΑΚΕΣ ΤΙΜΕΣ", isItalic: false, color: "text-white" },
  { text: "★", isItalic: false, color: "text-violet-500" },
  { text: "ΕΠΙΚΟΙΝΩΝΗΣΕ ΤΩΡΑ", isItalic: true, color: "text-white" },
  { text: "★", isItalic: false, color: "text-violet-500" },
];
---

<div class="overflow-hidden border-y-4 border-black bg-zinc-950 py-2 md:py-4 -rotate-2 scale-105 my-12 font-syne">
  <div class="flex whitespace-nowrap animate-marquee cursor-default">
    <div class="flex items-center">
      {marqueeItems.map((item) => (
        <span class:list={["text-sm md:text-3xl font-black uppercase mx-2 md:mx-8", item.color, { italic: item.isItalic }]}>
          {item.text}
        </span>
      ))}
    </div>
    <div class="flex items-center" aria-hidden="true">
      {marqueeItems.map((item) => (
        <span class:list={["text-sm md:text-3xl font-black uppercase mx-4 md:mx-8", item.color, { italic: item.isItalic }]}>
          {item.text}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  :root {
    --marquee-speed: 20s; /* Default desktop speed */
  }

  /* Faster speed for mobile devices */
  @media (max-width: 768px) {
    :root {
      --marquee-speed: 10s; 
    }
  }

  .animate-marquee {
    display: flex;
    width: max-content;
    /* Use the variable here */
    animation: marquee var(--marquee-speed) linear infinite;
  }

  .animate-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>